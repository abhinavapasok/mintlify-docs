{
  "$schema": "https://mintlify.com/docs.json",
  "name": "KomKits Docs",
  "theme": "mint",
  "colors": {
    "primary": "#6F6A01",
    "light": "#FEF102",
    "dark": "#6F6A01"
  },
  "logo": {
    "light": "/logo/komkits-wordmark-light.png",
    "dark": "/logo/komkits-wordmark-dark.png"
  },
  "favicon": "/favicon.png",
  "fonts": {
    "heading": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Public Sans"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
